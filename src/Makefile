###############################################################################
# Compiler and base flags
###############################################################################
CXX      := g++
# Added -Wall -Wextra for safety, and -MMD -MP for automatic header dependency tracking
CXXFLAGS := -std=c++17 -Wall -Wextra -MMD -MP
CPPFLAGS :=
LDFLAGS  :=

###############################################################################
# Determine OS and set OS-specific variables
###############################################################################
ifeq ($(OS),Windows_NT)
    OS_NAME := Windows
    RM      := del /Q
    MKDIR   := mkdir
    EXE     := Thrawn.exe
    STACK_FLAG := -Wl,--stack,8388608
else
    UNAME_S := $(shell uname -s)
    ifeq ($(UNAME_S),Linux)
        OS_NAME := Linux
        RM      := rm -f
        MKDIR   := mkdir -p
    else ifeq ($(UNAME_S),Darwin)
        OS_NAME := macOS
        RM      := rm -f
        MKDIR   := mkdir -p
    endif
    EXE := Thrawn
    STACK_FLAG := # No stack flag for Linux/macOS
endif

###############################################################################
# Source and object files
###############################################################################
SOURCES := $(wildcard *.cpp)
OBJECTS := $(SOURCES:.cpp=.o)
# Dependency files generated by -MMD
DEPS    := $(OBJECTS:.o=.d)

###############################################################################
# Build type and flags
###############################################################################
BUILD ?= release
ARCH  ?= native

OPT_FLAGS  := -O3 -flto=auto
ARCH_FLAGS :=
MACOS_MIN_VERSION := 10.15

ifeq ($(OS_NAME),Linux)
    ARCH_DETECTED := $(shell uname -m)
    CXXFLAGS += -pthread
    LDFLAGS += -pthread
else ifeq ($(OS_NAME),macOS)
    ARCH_DETECTED := $(shell uname -m)
    ifeq ($(ARCH_DETECTED),arm64)
        MACOS_MIN_VERSION := 11.0
    endif
    ARCH_FLAGS += -mmacosx-version-min=$(MACOS_MIN_VERSION)
else ifeq ($(OS_NAME),Windows)
    ARCH_DETECTED := $(PROCESSOR_ARCHITECTURE)
    CPPFLAGS += -DWIN32
endif

# -----------------------------------------------------------------------------
# Architecture specific flags
# -----------------------------------------------------------------------------
ifeq ($(ARCH),native)
    ifeq ($(ARCH_DETECTED),x86_64)
        CPPFLAGS += -DUSE_AVX2
        ARCH_FLAGS += -march=native -mfma -mbmi -mbmi2 -mpopcnt
    else ifeq ($(ARCH_DETECTED),AMD64)
        CPPFLAGS += -DUSE_AVX2
        ARCH_FLAGS += -march=native -mfma -mbmi -mbmi2 -mpopcnt
    else ifeq ($(ARCH_DETECTED),arm64)
        CPPFLAGS += -DUSE_NEON
        ARCH_FLAGS += -march=native
    else ifeq ($(ARCH_DETECTED),aarch64)
        CPPFLAGS += -DUSE_NEON
        ARCH_FLAGS += -march=native
    else ifeq ($(ARCH_DETECTED),ARM64)
        CPPFLAGS += -DUSE_NEON
        ARCH_FLAGS += -march=native
    endif
else ifeq ($(ARCH),x86-64-avx512)
    CPPFLAGS += -DUSE_AVX512
    ARCH_FLAGS += -mavx512f -mavx512bw -mavx512dq -mavx512vnni -mavx2 -mfma -mbmi -mbmi2 -mpopcnt
else ifeq ($(ARCH),x86-64-avx2)
    CPPFLAGS += -DUSE_AVX2
    ARCH_FLAGS += -mavx2 -mfma -mbmi -mbmi2 -mpopcnt
else ifeq ($(ARCH),arm64-neon)
    CPPFLAGS += -DUSE_NEON
else ifeq ($(ARCH),arm64-neon-dotprod)
    CPPFLAGS += -DUSE_NEON
    ifeq ($(OS_NAME),macOS)
        ARCH_FLAGS += -march=native
    else
        ARCH_FLAGS += -march=armv8.2-a+dotprod
    endif
else
    $(error Unsupported ARCH '$(ARCH)'. Use native, x86-64-avx512, x86-64-avx2, arm64-neon, or arm64-neon-dotprod)
endif

# -----------------------------------------------------------------------------
# Build Types
# -----------------------------------------------------------------------------
ifeq ($(BUILD),debug)
    CPPFLAGS += -DDEBUG_BUILD
    CXXFLAGS += -g $(ARCH_FLAGS)
else ifeq ($(BUILD),release)
    CPPFLAGS += -DRELEASE_BUILD -DNDEBUG
    CXXFLAGS += $(OPT_FLAGS) $(ARCH_FLAGS)
    # LTO requires the optimization flag at link time as well
    LDFLAGS  += $(OPT_FLAGS) 
endif

###############################################################################
# Targets
###############################################################################
.PHONY: all clean

# Removed the forced "clean" on every make call so incremental builds work
all: $(EXE)

$(EXE): $(OBJECTS)
	$(CXX) $(CXXFLAGS) $(LDFLAGS) $(STACK_FLAG) -o $@ $^

%.o: %.cpp
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) -c -o $@ $<

clean:
	$(RM) $(OBJECTS) $(DEPS) $(EXE)

# Include automatically generated dependency files
-include $(DEPS)